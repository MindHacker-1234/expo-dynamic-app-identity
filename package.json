{
  "name": "@praneeth26/expo-dynamic-app-identity",
  "version": "1.2.0",
  "description": "Comprehensive Expo plugin for dynamic app icon and label switching. Features: DEFAULT alias support, deep link migration, app label switching, immediate switch, toast feedback, and adaptive icon support.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "clean": "rm -rf build plugin/build",
    "build": "node ./node_modules/typescript/bin/tsc && node ./node_modules/typescript/bin/tsc --build ./plugin",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "expo",
    "expo-plugin",
    "react-native",
    "dynamic-icon",
    "dynamic-app-icon",
    "app-icon",
    "app-label",
    "app-identity",
    "activity-alias"
  ],
  "author": "Praneeth",
  "license": "MIT",
  "peerDependencies": {
    "expo": ">=52.0.0"
  },
  "dependencies": {
    "@expo/config-plugins": "^9.0.0",
    "@expo/image-utils": "^0.6.0",
    "expo-modules-core": "^2.0.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/praneeth26/expo-dynamic-app-identity.git"
  },
  "files": [
    "build",
    "plugin/build",
    "android",
    "ios",
    "app.plugin.js",
    "expo-module.config.json",
    "LICENSE",
    "README.md"
  ]
}
